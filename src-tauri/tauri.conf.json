{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "blink",
  "version": "0.1.0",
  "identifier": "com.suyash.blink",
  "build": {
    "beforeDevCommand": "npm run start",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist/blink/browser"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 720,
        "height": 380,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage"],
    "shortDescription": "Keyboard-driven app launcher for Linux",
    "longDescription": "Blink is a lightweight launcher: press Ctrl+Space, type an application name, and open it. Ships as a standard .deb for Debian and Ubuntu-based systems.",
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libglib2.0-bin",
          "libgtk-3-bin"
        ],
        "section": "utils",
        "priority": "optional"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
